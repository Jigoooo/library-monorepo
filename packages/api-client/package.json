{
  "name": "@jigoooo/api-client",
  "version": "0.2.4",
  "description": "Axios 기반 API 클라이언트 — 토큰 갱신, 401 재시도, camelCase/snakeCase 변환 지원",
  "keywords": [
    "axios",
    "api",
    "client",
    "token",
    "refresh",
    "401",
    "camelCase",
    "snakeCase"
  ],
  "author": "Jigoooo",
  "license": "MIT",
  "homepage": "https://github.com/Jigoooo/library-monorepo/tree/master/packages/api-client",
  "repository": {
    "type": "git",
    "url": "https://github.com/Jigoooo/library-monorepo.git",
    "directory": "packages/api-client"
  },
  "bugs": {
    "url": "https://github.com/Jigoooo/library-monorepo/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "pnpm build",
    "publish:dry": "npm publish --dry-run"
  },
  "dependencies": {
    "axios": "^1.13.5",
    "qs": "^6.14.1"
  },
  "devDependencies": {
    "@types/qs": "^6.15.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  }
}
